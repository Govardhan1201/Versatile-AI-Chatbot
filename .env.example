# ===========================
# VERSATILE AI BOT — Environment Variables
# Copy this file to .env and fill in your values.
# ===========================

# ----- LLM Provider -----
# Set to "openai" for real AI, "mock" for demo mode (no API key needed)
LLM_PROVIDER=mock

# OpenAI API Key (only needed when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here

# OpenAI model to use
OPENAI_MODEL=gpt-4o-mini

# OpenAI base URL (change to use Azure OpenAI or other compatible providers)
OPENAI_BASE_URL=https://api.openai.com/v1

# ----- Embeddings -----
# "local" uses @xenova/transformers (no API key, slower first run)
# "openai" uses text-embedding-ada-002 (requires OPENAI_API_KEY)
EMBEDDINGS_PROVIDER=local

# ----- Server -----
PORT=3001
NODE_ENV=development

# ----- Admin Dashboard -----
# Password for the admin login screen
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# JWT secret for admin session tokens
ADMIN_JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin session expiry (e.g. 24h, 7d)
ADMIN_SESSION_EXPIRY=24h

# ----- Storage -----
# Path for all runtime data (vector stores, logs, analytics)
DATA_DIR=./data

# Tenants config directory
TENANTS_DIR=./tenants

# ----- Rate Limiting -----
# Max chat requests per IP per minute (per tenant, overridden in tenant config)
DEFAULT_RATE_LIMIT=20

# ----- Widget / CORS -----
# In production, restrict to your actual domains
# In development, wildcard is fine
CORS_ORIGINS=*

# ----- Crawling -----
# Max pages the crawler will fetch per ingest job
CRAWLER_MAX_PAGES=50
CRAWLER_DELAY_MS=500
